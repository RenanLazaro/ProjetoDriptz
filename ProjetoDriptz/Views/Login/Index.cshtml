@model LoginModel
@{
    Layout = "_LayoutDeslogado";
    ViewData["Title"] = "Login";
}

<style>
    body {
        background: #1a1a1a;
        margin: 0;
        padding: 0;
    }

    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
        flex-direction: column;
    }

    .logo-container {
        margin-bottom: 30px;
        text-align: center;
    }

        .logo-container img {
            width: 150px;
            height: 150px;
            object-fit: contain;
            filter: drop-shadow(0 4px 15px rgba(255, 102, 0, 0.5));
        }

    .login-container {
        background: #000;
        border: 2px solid #ff6600;
        border-radius: 15px;
        padding: 40px;
        box-shadow: 0 8px 32px rgba(255, 102, 0, 0.3);
        max-width: 400px;
        width: 100%;
    }

    .login-title {
        color: #ff6600;
        text-align: center;
        font-size: 2rem;
        font-weight: bold;
        margin-bottom: 30px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .alert-danger {
        background: linear-gradient(135deg, #ff6600 0%, #ff8533 100%);
        border: none;
        border-radius: 8px;
        color: #000;
        font-weight: 600;
        padding: 15px;
        margin-bottom: 20px;
        position: relative;
    }

    .close-alert {
        background: #000;
        color: #ff6600;
        border: none;
        padding: 5px 12px;
        border-radius: 5px;
        font-weight: bold;
        cursor: pointer;
        position: absolute;
        right: 10px;
        top: 10px;
        transition: all 0.3s ease;
    }

        .close-alert:hover {
            background: #ff6600;
            color: #000;
            transform: scale(1.1);
        }

    .form-group {
        margin-bottom: 25px;
    }

        .form-group label {
            color: #ff6600;
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .form-control {
        background: #1a1a1a;
        border: 2px solid #333;
        border-radius: 8px;
        color: #fff;
        padding: 12px 15px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            background: #000;
            border-color: #ff6600;
            box-shadow: 0 0 15px rgba(255, 102, 0, 0.4);
            color: #fff;
            outline: none;
        }

        .form-control::placeholder {
            color: #666;
        }

    .field-validation-error {
        color: #ff6600;
        font-size: 0.875rem;
        margin-top: 5px;
        display: block;
    }

    .btn-primary {
        background: linear-gradient(135deg, #ff6600 0%, #ff8533 100%);
        border: none;
        border-radius: 8px;
        color: #000;
        font-weight: bold;
        font-size: 1.1rem;
        padding: 15px;
        text-transform: uppercase;
        letter-spacing: 2px;
        transition: all 0.3s ease;
        cursor: pointer;
    }

        .btn-primary:hover {
            background: linear-gradient(135deg, #ff8533 0%, #ff6600 100%);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(255, 102, 0, 0.5);
        }

        .btn-primary:active {
            transform: translateY(0);
        }
</style>

<div class="login-wrapper">
    <div class="logo-container">
        <img src="~/img/driptz-logo.png" alt="Driptz Logo">
    </div>

    <div class="login-container">
        <h2 class="login-title">Login</h2>

        @if (TempData["MensagemErro"] != null)
        {
            <div class="alert alert-danger" role="alert">
                <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
                @TempData["MensagemErro"]
            </div>
        }

        @if (TempData["MensagemSucesso"] != null)
        {
            <div class="alert alert-success" role="alert">
                <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
                @TempData["MensagemSucesso"]
            </div>

        }

        <form asp-controller="Login" asp-action="Entrar" method="post">

            <div class="form-group">
                <label for="login">Login</label>
                <input type="text" asp-for="Login" class="form-control" id="login">
                @Html.ValidationMessageFor(x => x.Login)
            </div>

            <div class="form-group">
                <label for="senha">Senha</label>
                <input type="password" asp-for="Senha" class="form-control" id="senha">
                @Html.ValidationMessageFor(x => x.Senha)
            </div>

            <p class="mb-4 text-sm-center mx-auto"> Esqueceu sua Senha?
                <a  asp-action="RedefinirSenha" asp-controller="Login" class="text-primary font-weight-bold">Redefinir minha Senha</a>
            </p>

            <br>
            <button type="submit" class="btn btn-primary btn-block w-100">Entrar</button>

        </form>
    </div>
</div>