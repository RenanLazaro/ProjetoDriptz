@using ProjetoDriptz.Enums
@model List<VendaModel>
@{
    ViewData["Title"] = "Vendas";
}

<div class="text-center">


    <br />

    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemSucesso"]
        </div>
    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemErro"]
        </div>
    }

    <h1>Vendas Realizadas</h1>

    <table class="table" id="table-grid">
        <thead>
            <tr>
                <th scope="col">Produto</th>
                <th scope="col">Tamanho</th>
                <th scope="col">Quantidade</th>
                <th scope="col">Valor</th>
                <th scope="col">Forma de Pagamento</th>
                <th scope="col">Mais de uma forma de pagamento?</th>
                <th scope="col">Data da Venda</th>
                <th scope="col">Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (VendaModel venda in Model)
                {
                    <tr>
            
                        <td>@venda.Produto?.NomeProduto</td>
                        <td>
                            @(venda.Tamanho == (int)TamanhoProduto.P ? "P"
                                                : venda.Tamanho == (int)TamanhoProduto.M ? "M"
                                                : venda.Tamanho == (int)TamanhoProduto.G ? "G"
                                                : venda.Tamanho == (int)TamanhoProduto.GG ? "GG"
                                                : "Indefinido")
                </td>
                <td>@venda.Quantidade</td>
                <td>R$ @venda.PrecoItem</td>
                   <td>
                 @(venda.FormaDePagamento == (int)FormaDePagamento.Dinheiro ? "Dinheiro"
                                                : venda.FormaDePagamento == (int)FormaDePagamento.Pix ? "Pix"
                                                : venda.FormaDePagamento == (int)FormaDePagamento.Cartao ? "Cartão Crédito/Débito"
                : "Indefinido")
                </td>
                <td>@(venda.PossuiMaisDeUmaFormaPagamento ? "Sim" : "Não")</td>
                <td>@venda.DataVenda.ToString("dd/MM/yyyy")</td>

                <td>
                    <div class="btn-group" role="group" aria-label="Ações">
                        <a role="button" class="btn btn-primary" asp-route-id="@venda.Id" asp-controller="Venda" asp-action="Editar">Editar</a>
                        <a role="button" class="btn btn-danger" asp-route-id="@venda.Id" asp-controller="Venda" asp-action="ApagarConfirmacao">Apagar</a>
                    </div>
                </td>
            </tr>
                        }
            }
        </tbody>
    </table>
</div>
