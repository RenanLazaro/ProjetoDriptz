@using ProjetoDriptz.Enums
@using ProjetoDriptz.Models.ViewModels
@model List<VendaVm>

@{
    ViewData["Title"] = "Vendas";
}

<style>
    .product-image {
        width: 40px;
        height: 40px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #ddd;
        margin-right: 6px;
    }

    #table-grid td {
        vertical-align: middle;
    }
</style>

<div class="text-center">

    <h1>Vendas Realizadas</h1>

    <table class="table table-striped" id="table-grid">
        <thead>
            <tr>
                <th>Produtos</th>
                <th>Quantidade</th>
                <th>Valores</th>
                <th>Forma de Pagamento</th>
                <th>Data da Venda</th>
                <th>Ações</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var venda in Model)
            {
                <tr>
                    <!-- PRODUTOS -->
                    <td>
                        @foreach (var item in venda.Itens)
                        {
                            <div class="d-flex align-items-center mb-1">
                                @if (!string.IsNullOrEmpty(item.ImagemProduto))
                                {
                                    <img src="~/imagens/produtos/@item.ImagemProduto"
                                         class="product-image" />
                                }
                                <span>@item.NomeProduto</span>
                            </div>
                        }
                    </td>

                    <!-- QUANTIDADES -->
                    <td>
                        @foreach (var item in venda.Itens)
                        {
                            <div>@item.Quantidade</div>
                        }
                    </td>

                    <!-- VALORES -->
                    <td>
                        @foreach (var item in venda.Itens)
                        {
                            <div>R$ @item.PrecoUnitario</div>
                        }
                    <hr />
                    <strong>Total: R$ @venda.ValorTotal.ToString("N2")</strong>
                </td>

                <!-- PAGAMENTO -->
                <td>
                    @(venda.FormaDePagamento == (int)FormaDePagamento.Dinheiro ? "Dinheiro"
                                        : venda.FormaDePagamento == (int)FormaDePagamento.Pix ? "Pix"
                                        : "Cartão")
                </td>

                    <!-- DATA -->
                    <td>@venda.DataVenda.ToString("dd/MM/yyyy")</td>

                    <!-- AÇÕES -->
                    <td>
                        <div class="btn-group">
                            <a class="btn btn-primary"
                               asp-controller="Venda"
                               asp-action="Editar"
                               asp-route-id="@venda.Id">
                                Editar
                            </a>

                            <a class="btn btn-danger"
                               asp-controller="Venda"
                               asp-action="ApagarConfirmacao"
                               asp-route-id="@venda.Id">
                                Apagar
                            </a>
                        </div>
                    </td>
                </tr>
                        }
        </tbody>
    </table>
</div>
