@using ProjetoDriptz.Enums
@using ProjetoDriptz.Models.ViewModels
@model EstoqueVm
@{
    ViewData["Title"] = "Editar Estoque";
}

<h2>teste de vercionamento do git</h2>

<div class="text-center">

    <h1 class="display-4">Editar Estoque</h1>

</div>

<form asp-controller="Estoque" asp-action="Alterar" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label for="ProdutoId">Produto</label>
        <select asp-for="ProdutoId" class="form-control" asp-items="@((List<SelectListItem>)ViewData["Produtos"])">
            <option value="">-- Selecione um Produto --</option>
        </select>
        @Html.ValidationMessageFor(x => x.ProdutoId)
    </div>

    <div class="form-group">
        <label for="Tamanho">Tamanho</label>
        <select asp-for="Tamanho" class="form-control"
                asp-items="Html.GetEnumSelectList<TamanhoProduto>()">
        </select>

        @Html.ValidationMessageFor(x => x.Tamanho)
    </div>


    <div class="form-group">
        <label for="cor">Cor</label>
        <input type="text" asp-for="Cor" class="form-control" placeholder="Cor">

        @Html.ValidationMessageFor(x => x.Cor)
    </div>



    <div class="form-group">
        <label for="quantidade">Quantidade</label>
        <input type="number" asp-for="Quantidade" class="form-control" placeholder="Quantidade" min="0">
        @Html.ValidationMessageFor(x => x.Quantidade)
    </div>

    <br />
    <button type="submit" class="btn btn-primary w-100">Alterar</button>
    <br />
    <br />
    <a class="btn btn-secondary d-block" asp-controller="Estoque" asp-action="Index" role="button">Voltar</a>
</form>




