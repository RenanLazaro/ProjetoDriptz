@using ProjetoDriptz.Enums
@model List<EstoqueModel>
@{
    ViewData["Title"] = "Estoque de Produtos";
}



<div class="text-center">


    <div class="d-grid gap-2 d-md-flex justify-content-md-start">

        <a class="btn btn-primary" role="button" asp-controller="Estoque" asp-action="Criar">Cadastrar Estoque do Produto</a>

    </div>

    <br />


    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemSucesso"]
        </div>

    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemErro"]
        </div>

    }




    <h1>Produtos em Estoque</h1>

    <table class="table" id="table-grid">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Produto</th>
                <th scope="col">Tamanho</th>
                <th scope="col">Cor</th>
                <th scope="col">Quantidade</th>
                <th scope="col"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (EstoqueModel estoque in Model)
                {

                    <tr>
                        <th scope="row">@estoque.Id</th>
                        <td>@estoque.Produto?.NomeProduto</td>
           
                        <td>
                            @(estoque.Tamanho == (int)TamanhoProduto.P ? "P"
                                                : estoque.Tamanho == (int)TamanhoProduto.M ? "M"
                                                : estoque.Tamanho == (int)TamanhoProduto.G ? "G"
                                                : estoque.Tamanho == (int)TamanhoProduto.GG ? "GG"
                                                : "Indefinido")
                        </td>
                        <td>@estoque.Cor</td>
                        <td>@estoque.Quantidade</td>
                <td>
                    <div class="btn-group" role="group" aria-label="Ações">
                        <a role="button" class="btn btn-success"  asp-route-id="@estoque.Id" asp-controller="Venda"   asp-action="Criar">Realizar Venda</a>
                        <a role="button" class="btn btn-primary" asp-route-id="@estoque.Id" asp-controller="Estoque" asp-action="Editar">Editar</a>
                        <a role="button" class="btn btn-danger" asp-route-id="@estoque.Id" asp-controller="Estoque" asp-action="ApagarConfirmacao">Apagar</a>
                    </div>
                </td>
            </tr>
                        }
            }

        </tbody>
    </table>

</div>




