@model EstoqueModel
@{
    ViewData["Title"] = "Confirmação de apagar o Estoque";
}

<div class="text-center">


 <h3>
     Realmente deseja apagar o Produto  (@Model.Produto?.NomeProduto)?

 </h3>

</div>

<a role="button" class="btn btn-primary w-100" asp-controller="Estoque" asp-action="Index">Cancelar Exclusão</a>
<br />
<a role="button" class="btn btn-danger w-100" asp-controller="Estoque" asp-action="Apagar" asp-route-id="@Model.Id">Confirmar Exclusão</a>