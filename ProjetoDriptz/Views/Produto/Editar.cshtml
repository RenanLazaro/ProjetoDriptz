@using ProjetoDriptz.Enums
@using ProjetoDriptz.Models.ViewModels
@model ProdutoVm

@{
    ViewData["Title"] = "Editar Produto";
}

<style>
    .image-preview {
        max-width: 300px;
        margin-top: 15px;
        border: 2px dashed #dee2e6;
        border-radius: 8px;
        padding: 15px;
        background-color: #f8f9fa;
        text-align: center;
    }

        .image-preview img {
            width: 100%;
            max-height: 300px;
            object-fit: contain;
            border-radius: 5px;
        }
</style>

<div class="text-center">
    <h1 class="display-4">Editar Produto</h1>
</div>

<form asp-controller="Produto"
      asp-action="Alterar"
      method="post"
      enctype="multipart/form-data">

    <!-- 🔒 Campos essenciais -->
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="Imagem" />

    <div class="form-group">
        <label>Nome</label>
        <input asp-for="NomeProduto" class="form-control" />
        @Html.ValidationMessageFor(x => x.NomeProduto)
    </div>

    <div class="form-group">
        <label>Tipo</label>
        <select asp-for="Tipo"
                class="form-control"
                asp-items="Html.GetEnumSelectList<TipoProduto>()">
            <option value="">Selecione um tipo</option>
        </select>
        @Html.ValidationMessageFor(x => x.Tipo)
    </div>

    <div class="form-group">
        <label asp-for="PrecoCusto">Preço de Custo</label>
        <input asp-for="PrecoCusto" type="number" step="0.01" min="0" class="form-control" placeholder="0,00" />
        @Html.ValidationMessageFor(x => x.PrecoCusto)
    </div>

    <div class="form-group">
        <label>Preço</label>
        <input asp-for="Preco" type="number" step="0.01" min="0" class="form-control" />
        @Html.ValidationMessageFor(x => x.Preco)
    </div>

    <hr />

    <!-- 📤 Upload da nova imagem -->
    <div class="form-group">
        <label>Imagem do Produto</label>
        <input asp-for="ImagemUpload"
               type="file"
               class="form-control-file"
               accept="image/*"
               id="imagemInput" />
        <small class="form-text text-muted">
            JPG, PNG ou GIF (máx. 5MB)
        </small>
        <span asp-validation-for="ImagemUpload" class="text-danger"></span>
    </div>

    <!-- 🖼️ Preview (imagem atual ou nova) -->
    <div class="image-preview"
         id="imagePreview"
         style="display:@(!string.IsNullOrEmpty(Model.Imagem) ? "block" : "none")">

        <p class="text-muted mb-2">
            Imagem atual do produto:
        </p>

        <img id="previewImg"
             src="@(!string.IsNullOrEmpty(Model.Imagem)
                                 ? Url.Content($"~/imagens/produtos/{Model.Imagem}")
                                 : "")"
             alt="Imagem do produto" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary w-100">
        Alterar
    </button>

    <br /><br />

    <a asp-controller="Produto"
       asp-action="Index"
       class="btn btn-secondary w-100">
        Voltar
    </a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const imagemInput = document.getElementById('imagemInput');
            const imagePreview = document.getElementById('imagePreview');
            const previewImg = document.getElementById('previewImg');

            imagemInput.addEventListener('change', function (e) {
                const file = e.target.files[0];

                if (!file) return;

                // tamanho máximo 5MB
                if (file.size > 5 * 1024 * 1024) {
                    alert('Arquivo muito grande! Máximo 5MB.');
                    imagemInput.value = '';
                    return;
                }

                if (!file.type.startsWith('image/')) {
                    alert('Selecione apenas imagens.');
                    imagemInput.value = '';
                    return;
                }

                const reader = new FileReader();
                reader.onload = function (e) {
                    previewImg.src = e.target.result;
                    imagePreview.style.display = 'block';
                };

                reader.readAsDataURL(file);
            });
        });


    </script>
}
