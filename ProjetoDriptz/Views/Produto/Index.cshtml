@using ProjetoDriptz.Enums
@model List<ProdutoModel>
@{
    ViewData["Title"] = "Lista de Produtos";
}



<div class="text-center">
    
   
    <div class="d-grid gap-2 d-md-flex justify-content-md-start">
     
        <a class="btn btn-primary" role="button" asp-controller="Produto" asp-action="Criar">Adicionar Novo Produto</a>

    </div>
    
    <br />


    @if (TempData["MensagemSucesso"] != null)
    {
        <div class="alert alert-success" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemSucesso"]
        </div>

    }

    @if (TempData["MensagemErro"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <button type="button" class="btn btn-danger btn-sm close-alert" arial-label="Close">X</button>
            @TempData["MensagemErro"]
        </div>

    }




    <h1>Lista de Produtos</h1>

    <table class="table" id="table-grid">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Produto</th>
                <th scope="col">Tipo</th>
                <th scope="col">Tamanho</th>
                <th scope="col">Quantidade</th>
                <th scope="col"></th>
            </tr>
        </thead>
        <tbody>
            @if(Model != null && Model.Any())
            {
                foreach( ProdutoModel produto in Model)
                {

                    <tr>
                        <th scope="row">@produto.Id</th>
                        <td>@produto.NomeProduto</td>
                        <td>
                            @(produto.Tipo == (int)TipoProduto.Camisa ? "Camisa"
                                                : produto.Tipo == (int)TipoProduto.BlusaDeFrio ? "Blusa De Frio"
                                                : produto.Tipo == (int)TipoProduto.Boné ? "Boné"
                                                : produto.Tipo == (int)TipoProduto.Bermuda ? "Bermuda"
                            : "Indefinido")
                                       
                        <td>
                            @(produto.Tamanho == (int)TamanhoProduto.P ? "P"
                            : produto.Tamanho == (int)TamanhoProduto.M ? "M"
                            : produto.Tamanho == (int)TamanhoProduto.G ? "G"
                            : produto.Tamanho == (int)TamanhoProduto.GG ? "GG"
                            : "Indefinido")
                         </td>
                        <td >@produto.Preco</td>
                        <td>
                            <div class="btn-group" role="group" aria-label="Ações">
                                <a role="button" class="btn btn-primary" asp-route-id="@produto.Id" asp-controller="Produto" asp-action="Editar">Editar</a>
                                <a role="button" class="btn btn-danger" asp-route-id="@produto.Id" asp-controller="Produto" asp-action="ApagarConfirmacao">Apagar</a>
                            </div>
                        </td>
                    </tr>
                }
            }

        </tbody>
    </table>

</div>




