@using ProjetoDriptz.Enums
@model UsuarioModel
@{
    ViewData["Title"] = "Cadastrar Usuário";
}



<div class="text-center">

    <h1 class="display-4">Cadastrar Usuário</h1>

</div>


<form asp-controller="Usuario" asp-action="Criar" method="post">
    <div class="form-group">
        <label for="produto">Nome</label>
        <input type="text" asp-for="Nome" class="form-control" placeholder="Nome do Usuário">
        @Html.ValidationMessageFor(x => x.Nome)
    </div>
    
    <div class="form-group">
        <label for="tipo">Email</label>
        <input type="text" asp-for="Email" class="form-control" placeholder="Email do Usuário">

        @Html.ValidationMessageFor(x => x.Email)
    </div>

    <div class="form-group">
        <label for="Login">Login do Usuario</label>
        <input type="text" asp-for="Login" class="form-control" placeholder="Login do Usuário">
        @Html.ValidationMessageFor(x => x.Login)
    </div>


    <div class="form-group">
        <label for="produto">Senha</label>
        <input type="password" asp-for="Senha" class="form-control" placeholder="Digite sua Senha">
        @Html.ValidationMessageFor(x => x.Senha)
    </div>
    
    
    <div class="form-group">
        <label for="Perfil">Perfil do Usuário</label>
        <select asp-for="Perfil" class="form-control"
            asp-items="Html.GetEnumSelectList<PerfilUsuario>()">
        </select>

        @Html.ValidationMessageFor(x => x.Perfil)
    </div>

   
    <br />
    <button type="submit" class="btn btn-primary w-100">Adicionar</button>
    <br />
    <br />
    <a class="btn btn-secondary d-block" asp-controller="Usuario" asp-action="Index" role="button">Voltar</a>
</form>



