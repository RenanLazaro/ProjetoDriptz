@model UsuarioModel
@{
    ViewData["Title"] = "Confirmação de apagar o Produto";
}

<div class="text-center">


 <h3>
     Realmente deseja apagar o Usuário (@Model.Nome)?

 </h3>

</div>

<a role="button" class="btn btn-primary w-100" asp-controller="Usuario" asp-action="Index">Cancelar Exclusão</a>
<br />
<a role="button" class="btn btn-danger w-100" asp-controller="Usuario" asp-action="Apagar" asp-route-id="@Model.Id">Confirmar Exclusão</a>