@* =====================================================================
   ARQUIVO: Views/Pedido/Checkout.cshtml  — ARQUIVO NOVO
   ===================================================================== *@
@model ProjetoDriptz.Models.ViewModels.CheckoutVm
@{
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    ViewData["Title"] = "Finalizar Pedido";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4">
        <i class="bi bi-clipboard-check"></i> Finalizar Pedido
    </h2>

    <form asp-action="Checkout" method="post">
        <div class="row g-4">

            @* ---- Dados do cliente ---- *@
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Seus dados</h5>

                        <div class="mb-3">
                            <label asp-for="NomeCliente" class="form-label"></label>
                            <input asp-for="NomeCliente" class="form-control" placeholder="Ex: João Silva" />
                            <span asp-validation-for="NomeCliente" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Telefone" class="form-label"></label>
                            <input asp-for="Telefone" class="form-control" placeholder="(27) 99999-9999" />
                            <span asp-validation-for="Telefone" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                @* ---- Tipo de entrega ---- *@
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Entrega</h5>

                        <div class="d-flex gap-3 mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="TipoEntrega"
                                       id="retirada" value="0"
                                       @(Model.TipoEntrega == ProjetoDriptz.Enums.TipoEntrega.Retirada ? "checked" : "")
                                       onchange="toggleEndereco(0)">
                                <label class="form-check-label" for="retirada">
                                    <i class="bi bi-shop"></i> Retirada no local
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="TipoEntrega"
                                       id="delivery" value="1"
                                       @(Model.TipoEntrega == ProjetoDriptz.Enums.TipoEntrega.Delivery ? "checked" : "")
                                       onchange="toggleEndereco(1)">
                                <label class="form-check-label" for="delivery">
                                    <i class="bi bi-bicycle"></i> Delivery
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="TipoEntrega" class="text-danger small"></span>

                        @* Campos de endereço (visíveis só no delivery) *@
                        <div id="campos-endereco" style="display:none">
                            <div class="mb-3">
                                <label asp-for="Endereco" class="form-label">Endereço *</label>
                                <input asp-for="Endereco" class="form-control" placeholder="Rua, número" />
                                <span asp-validation-for="Endereco" class="text-danger small"></span>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Complemento" class="form-label">Complemento</label>
                                    <input asp-for="Complemento" class="form-control" placeholder="Apto, casa..." />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Bairro" class="form-label">Bairro</label>
                                    <input asp-for="Bairro" class="form-control" placeholder="Bairro" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @* ---- Pagamento ---- *@
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Pagamento <small class="text-muted fw-normal">(pago na entrega/retirada)</small></h5>

                        <div class="mb-3">
                            <label asp-for="FormaDePagamento" class="form-label"></label>
                            <select asp-for="FormaDePagamento" class="form-select"
                                    asp-items="Html.GetEnumSelectList<ProjetoDriptz.Enums.FormaDePagamento>()"
                                    onchange="toggleTroco(this.value)">
                                <option value="">Selecione...</option>
                            </select>
                            <span asp-validation-for="FormaDePagamento" class="text-danger small"></span>
                        </div>

                        <div id="campo-troco" style="display:none">
                            <label asp-for="TrocoPara" class="form-label">Troco para (R$)</label>
                            <input asp-for="TrocoPara" class="form-control" type="number" step="0.01"
                                   placeholder="Ex: 50,00" />
                        </div>
                    </div>
                </div>

                @* ---- Observação ---- *@
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Observações gerais</h5>
                        <textarea asp-for="Observacao" class="form-control" rows="3"
                                  placeholder="Alguma instrução especial para o pedido?"></textarea>
                    </div>
                </div>
            </div>

            @* ---- Resumo do pedido ---- *@
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm sticky-top" style="top:80px">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3">Resumo do pedido</h5>

                        @foreach (var item in Model.Itens)
                        {
                            <div class="d-flex justify-content-between mb-2">
                                <span>@item.NomeProduto <span class="text-muted">x@item.Quantidade</span></span>
                                <span>R$ @item.SubTotal.ToString("F2")</span>
                            </div>
                            @if (!string.IsNullOrEmpty(item.Observacao))
                            {
                                <small class="text-secondary fst-italic d-block mb-1">↳ @item.Observacao</small>
                            }
                        }

                        <hr>
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Total</span>
                            <span class="text-success">R$ @Model.ValorTotal.ToString("F2")</span>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 mt-3 py-2">
                            <i class="bi bi-check-circle"></i> Confirmar pedido
                        </button>
                        <a href="@Url.Action("Carrinho")" class="btn btn-outline-secondary w-100 mt-2">
                            Voltar ao carrinho
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
<script>
    // Mostra/oculta campos de endereço
    function toggleEndereco(tipo) {
        document.getElementById('campos-endereco').style.display = tipo == 1 ? 'block' : 'none';
    }

    // Mostra/oculta campo de troco
    function toggleTroco(val) {
        // FormaDePagamento.Dinheiro = 0
        document.getElementById('campo-troco').style.display = val == '0' ? 'block' : 'none';
    }

    // Inicializa estado ao carregar a página
    document.addEventListener('DOMContentLoaded', () => {
        const delivery = document.getElementById('delivery');
        if (delivery && delivery.checked) toggleEndereco(1);

        const pgto = document.querySelector('[name="FormaDePagamento"]');
        if (pgto) toggleTroco(pgto.value);
    });
</script>
}
