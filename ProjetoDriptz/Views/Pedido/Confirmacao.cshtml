@* =====================================================================
   ARQUIVO: Views/Pedido/Confirmacao.cshtml  — ARQUIVO NOVO
   ===================================================================== *@
@model ProjetoDriptz.Models.ViewModels.PedidoConfirmadoVm
@{
    Layout = "~/Views/Shared/_LayoutCliente.cshtml";
    ViewData["Title"] = "Pedido Confirmado";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <div class="display-1 text-success"><i class="bi bi-check-circle-fill"></i></div>
        <h2 class="fw-bold mt-3">Pedido recebido!</h2>
        <p class="text-muted">Seu pedido <strong>#@Model.Id</strong> foi registrado com sucesso.</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">

            @* Status *@
            <div class="alert alert-warning d-flex align-items-center gap-2">
                <i class="bi bi-clock-history fs-5"></i>
                <span>Status atual: <strong>@Model.Status</strong></span>
            </div>

            @* Dados do cliente *@
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-3"><i class="bi bi-person"></i> Seus dados</h5>
                    <div class="row">
                        <div class="col-sm-6 mb-2">
                            <small class="text-muted d-block">Nome</small>
                            <strong>@Model.NomeCliente</strong>
                        </div>
                        <div class="col-sm-6 mb-2">
                            <small class="text-muted d-block">Telefone</small>
                            <strong>@Model.Telefone</strong>
                        </div>
                        <div class="col-sm-6 mb-2">
                            <small class="text-muted d-block">Entrega</small>
                            <strong>@Model.TipoEntrega</strong>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Endereco))
                        {
                            <div class="col-sm-6 mb-2">
                                <small class="text-muted d-block">Endereço</small>
                                <strong>@Model.Endereco @(Model.Bairro != null ? "— " + Model.Bairro : "")</strong>
                            </div>
                        }
                        <div class="col-sm-6 mb-2">
                            <small class="text-muted d-block">Pagamento</small>
                            <strong>@Model.FormaDePagamento</strong>
                        </div>
                        <div class="col-sm-6 mb-2">
                            <small class="text-muted d-block">Data</small>
                            <strong>@Model.DataPedido.ToString("dd/MM/yyyy HH:mm")</strong>
                        </div>
                    </div>
                </div>
            </div>

            @* Itens *@
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-3"><i class="bi bi-list-ul"></i> Itens do pedido</h5>
                    @foreach (var item in Model.Itens)
                    {
                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                            <div>
                                <span class="fw-semibold">@item.NomeProduto</span>
                                <span class="text-muted ms-2">x@item.Quantidade</span>
                                @if (!string.IsNullOrEmpty(item.Observacao))
                                {
                                    <br><small class="fst-italic text-secondary">@item.Observacao</small>
                                }
                            </div>
                            <span>R$ @item.SubTotal.ToString("F2")</span>
                        </div>
                    }
                    <div class="d-flex justify-content-between fw-bold fs-5 pt-3">
                        <span>Total</span>
                        <span class="text-success">R$ @Model.ValorTotal.ToString("F2")</span>
                    </div>
                </div>
            </div>

            <div class="text-center">
                <a href="@Url.Action("Cardapio")" class="btn btn-dark px-4">
                    <i class="bi bi-arrow-left"></i> Fazer novo pedido
                </a>
            </div>

        </div>
    </div>
</div>
