@* =====================================================================
   ARQUIVO: Views/Promocao/Editar.cshtml  — ARQUIVO NOVO
   ===================================================================== *@
@model ProjetoDriptz.Models.PromocaoModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Editar Promoção";
}

<div class="container py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Voltar
        </a>
        <h3 class="fw-bold mb-0"><i class="bi bi-pencil"></i> Editar Promoção</h3>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card border-0 shadow-sm">
                <div class="card-body">

                    <form asp-action="Editar" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Nome" class="form-label fw-semibold"></label>
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ProdutoId" class="form-label fw-semibold"></label>
                            <select asp-for="ProdutoId" class="form-select">
                                <option value="">Selecione o produto...</option>
                                @foreach (var produto in ViewBag.Produtos)
                                {
                                    <option value="@produto.Id"
                                            selected="@(produto.Id == Model.ProdutoId ? "selected" : null)">
                                        @produto.NomeProduto — R$ @produto.Preco.ToString("F2")
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="ProdutoId" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TipoDesconto" class="form-label fw-semibold"></label>
                            <select asp-for="TipoDesconto" class="form-select"
                                    asp-items="Html.GetEnumSelectList<ProjetoDriptz.Enums.TipoDesconto>()"
                                    onchange="toggleDesconto(this.value)">
                            </select>
                            <span asp-validation-for="TipoDesconto" class="text-danger small"></span>
                        </div>

                        <div id="campo-percentual" class="mb-3">
                            <label asp-for="DescontoPercentual" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <input asp-for="DescontoPercentual" class="form-control"
                                       type="number" min="1" max="100" />
                                <span class="input-group-text">%</span>
                            </div>
                            <span asp-validation-for="DescontoPercentual" class="text-danger small"></span>
                        </div>

                        <div id="campo-preco-fixo" class="mb-3" style="display:none">
                            <label asp-for="PrecoFixo" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input asp-for="PrecoFixo" class="form-control" type="number" step="0.01" />
                            </div>
                            <span asp-validation-for="PrecoFixo" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DataInicio" class="form-label fw-semibold"></label>
                                <input asp-for="DataInicio" class="form-control" type="date" />
                                <span asp-validation-for="DataInicio" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DataFim" class="form-label fw-semibold"></label>
                                <input asp-for="DataFim" class="form-control" type="date" />
                                <span asp-validation-for="DataFim" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="Ativo" class="form-check-input" type="checkbox" />
                            <label asp-for="Ativo" class="form-check-label">Promoção ativa</label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-dark px-4">
                                <i class="bi bi-check-lg"></i> Salvar alterações
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function toggleDesconto(valor) {
        document.getElementById('campo-percentual').style.display = valor == '0' ? 'block' : 'none';
        document.getElementById('campo-preco-fixo').style.display = valor == '1' ? 'block' : 'none';
    }
    document.addEventListener('DOMContentLoaded', () => {
        const sel = document.querySelector('[name="TipoDesconto"]');
        if (sel) toggleDesconto(sel.value);
    });
</script>
}
